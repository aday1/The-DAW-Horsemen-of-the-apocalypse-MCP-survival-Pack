<?xml version="1.0" encoding="utf-8"?>
<!-- DAW Horsemen MCP Survival Pack - per-user MSI. Build: scripts\build_msi.ps1 -->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Name="DAW Horsemen MCP Survival Pack"
           Manufacturer="aday"
           Version="$(var.ProductVersion)"
           UpgradeCode="F6125063-4D67-4BD0-A050-DF867C2A887D"
           Scope="perUser"
           Language="1033">
    <SummaryInformation Description="MCP bridges for REAPER, Bitwig, Renoise (+ Reason via REAPER). GUI + CARE heal."
                        Manufacturer="aday" />
    <MajorUpgrade DowngradeErrorMessage="A newer version of DAW Horsemen is already installed. Uninstall it first."
                  AllowSameVersionUpgrades="yes" />
    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />
    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="LocalProgramsFolder" Name="Programs">
        <Directory Id="INSTALLFOLDER" Name="DAW-Horsemen" />
      </Directory>
    </StandardDirectory>
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="AppMenuFolder" Name="DAW Horsemen" />
    </StandardDirectory>
    <StandardDirectory Id="DesktopFolder" />
    <Feature Id="Main" Title="DAW Horsemen" Description="Pack files, Start Menu + Desktop shortcuts" Level="1">
      <ComponentGroupRef Id="PayloadFiles" />
      <ComponentRef Id="RegInstallLocation" />
      <ComponentRef Id="StartMenuShortcuts" />
      <ComponentRef Id="DesktopShortcut" />
    </Feature>
    <ComponentGroup Id="PayloadFiles" Directory="INSTALLFOLDER">
      <Files Include="!(bindpath.Payload)\**" />
    </ComponentGroup>
    <Component Id="RegInstallLocation" Directory="INSTALLFOLDER" Guid="B0255213-9627-42E9-8693-0491F3F96C1B">
      <RegistryValue Root="HKCU" Key="Software\aday\DAW-Horsemen" Name="InstallLocation" Type="string" Value="[INSTALLFOLDER]" KeyPath="yes" />
      <RegistryValue Root="HKCU" Key="Software\aday\DAW-Horsemen" Name="Version" Type="string" Value="$(var.ProductVersion)" />
    </Component>
    <Component Id="StartMenuShortcuts" Directory="AppMenuFolder" Guid="A1C2D3E4-F5A6-4B7C-8D9E-0F1A2B3C4D5E">
      <Shortcut Id="SmGui" Name="DAW Horsemen" Description="GUI launcher - CARE, stacks, health" Target="[INSTALLFOLDER]launch_daw_mcp.bat" WorkingDirectory="INSTALLFOLDER" />
      <Shortcut Id="SmCare" Name="CARE (heal + health)" Description="Pull-if-behind, heal bridges, health check" Target="[INSTALLFOLDER]CARE.bat" WorkingDirectory="INSTALLFOLDER" />
      <Shortcut Id="SmSetup" Name="SETUP" Description="Quick start text" Target="[INSTALLFOLDER]SETUP.txt" WorkingDirectory="INSTALLFOLDER" />
      <RemoveFolder Id="RemoveAppMenuFolder" Directory="AppMenuFolder" On="uninstall" />
      <RegistryValue Root="HKCU" Key="Software\aday\DAW-Horsemen" Name="StartMenu" Type="integer" Value="1" KeyPath="yes" />
    </Component>
    <Component Id="DesktopShortcut" Directory="DesktopFolder" Guid="C3D4E5F6-A7B8-4C9D-0E1F-2A3B4C5D6E7F">
      <Shortcut Id="DeskGui" Name="DAW Horsemen" Description="GUI launcher - CARE, stacks, health" Target="[INSTALLFOLDER]launch_daw_mcp.bat" WorkingDirectory="INSTALLFOLDER" />
      <RegistryValue Root="HKCU" Key="Software\aday\DAW-Horsemen" Name="Desktop" Type="integer" Value="1" KeyPath="yes" />
    </Component>
  </Package>
</Wix>
